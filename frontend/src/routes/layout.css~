@theme {
  /* COLORS */
  --color-primary: rgb(var(--color-primary));
  --color-secondary: rgb(var(--color-secondary));
  --color-surface: rgb(var(--color-surface));

  /* TYPOGRAPHY */
  --font-sans: var(--font-sans);
  --font-display: var(--font-display);
}
